# ============================================================
# Messenginfo — Environment Variables
# Copy to .env.local and fill in values.
# NEVER commit .env.local — it is git-ignored.
# ============================================================

# --- App ---
NEXT_PUBLIC_APP_URL=https://messenginfo.com

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# --- DeepSeek AI (one key for all models) ---
# deepseek-reasoner → Mia consultation / legal reasoning (R1)
# deepseek-chat     → Mia FAQ simple responses
# deepseek-ocr      → document field extraction
# deepseek-v4       → document translation
DEEPSEEK_API_KEY=

# --- Email (Resend) ---
RESEND_API_KEY=
CONTACT_EMAIL_DESTINATION=2133611700uscis@gmail.com
EMAIL_FROM_ADDRESS=noreply@messenginfo.com

# --- Rate limiting (Upstash KV — optional, Supabase fallback active if absent) ---
KV_REST_API_URL=
KV_REST_API_TOKEN=

# --- Health endpoint ---
HEALTH_TOKEN=

# --- L1 / L3 safety-ops flags (all default OFF → byte-identical prod) ---
# Owner-only transitional certifier id. After the FK→profiles was dropped (Path B),
# this is a SOFT reference: any consistent uuid (a placeholder is fine until a real
# certifier/profile exists), e.g. 00000000-0000-0000-0000-000000000001.
OWNER_CERTIFIER_ID=
# L3 T0 durable audit of certifier overrides (append-only certifier_override_audit).
CERTIFIER_AUDIT_PERSIST_ENABLED=0
# L1 baseline: persist PII-free guard-block events to guard_block_events for rate calibration.
GUARD_BLOCK_METRICS_ENABLED=0
# L1 rate-alert threshold (blocks/hour). UNSET ⇒ Infinity ⇒ never alerts; set AFTER baseline.
GUARD_BLOCK_RATE_THRESHOLD=
# L1 A-full: per-failure-type ack + auto-ticket + owner alert on post-payment failures.
REFUND_AUTOTICKET_ENABLED=0
# Owner alert channel for the escalation/rate crons (direct Telegram webhook).
TELEGRAM_OWNER_WEBHOOK_URL=
# L0 certifier-override path in generate-pdf (canary only, after L2 PASS).
CERTIFIER_OVERRIDE_ENABLED=0
